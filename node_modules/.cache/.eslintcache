 used.","Identifier","unusedVar","jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md","JSXOpeningElement","'updateRoutine' is assigned a value but never used.","'restDays' is assigned a value but never used.","'setRestDay' is assigned a value but never used.","'removeRestDay' is assigned a value but never used.","'updateContact' is assigned a value but never used.","'subscriptionStatus' is assigned a value but never used.","The 'getSessionId' function makes the dependencies of useEffect Hook (at line 78) change on every render. To fix this, wrap the definition of 'getSessionId' in its own useCallback() Hook.","VariableDeclarator",["571"],"React Hook useEffect has a missing dependency: 'getSessionId'. Either include it or remove the dependency array.",["572"],"'immediateDowngradeToBasic' is assigned a value but never used.","'handleSubscriptionChange' is assigned a value but never used.","React Hook useEffect has missing dependencies: 'loading', 'refreshSubscription', and 'subscription'. Either include them or remove the dependency array.",["573"],"React Hook useEffect has a missing dependency: 'getRedirectUrl'. Either include it or remove the dependency array.",["574"],"'setUser' is assigned a value but never used.","'LoadingSpinner' is defined but never used.","'UpgradeCard' is defined but never used.","'hasTierAccess' is assigned a value but never used.","'currentTier' is assigned a value but never used.","'Users' is defined but never used.","'Video' is defined but never used.","'Shield' is defined but never used.","'React' is defined but never used.","'useState' is defined but never used.","'useEffect' is defined but never used.","'lastWorkout' is assigned a value but never used.","'updateProfile' is assigned a value but never used.","'Sun' is defined but never used.","'subscription' is assigned a value but never used.","React Hook useCallback has a missing dependency: 'removeToast'. Either include it or remove the dependency array.",["575"],["576"],"React Hook useEffect has a missing dependency: 'refreshSubscription'. Either include it or remove the dependency array.",["577"],"The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md","'generatePainInsights' is assigned a value but never used.",{"desc":"578","fix":"579"},{"kind":"580","justification":"581"},{"desc":"582","fix":"583"},{"desc":"584","fix":"585"},{"desc":"586","fix":"587"},{"desc":"588","fix":"589"},{"desc":"590","fix":"591"},{"desc":"592","fix":"593"},{"desc":"594","fix":"595"},"Update the dependencies array to be: [fetchSubscription, isAuthenticated, user._id]",{"range":"596","text":"597"},"directive","","Wrap the definition of 'getSessionId' in its own useCallback() Hook.",{"range":"598","text":"599"},"Update the dependencies array to be: [getSessionId, location, navigate, updateSubscriptionAfterPayment]",{"range":"600","text":"601"},"Update the dependencies array to be: [loading, refreshSubscription, subscription]",{"range":"602","text":"603"},"Update the dependencies array to be: [location.state, navigate, isAuthenticated, location.search, getRedirectUrl]",{"range":"604","text":"605"},"Update the dependencies array to be: [removeToast]",{"range":"606","text":"607"},"Update the dependencies array to be: [forceRefreshSubscription, getSessionId, navigate]",{"range":"608","text":"609"},"Update the dependencies array to be: [refreshSubscription]",{"range":"610","text":"611"},[4189,4217],"[fetchSubscription, isAuthenticated, user._id]",[685,805],"useCallback(() => {\r\n    const searchParams = new URLSearchParams(location.search);\r\n    return searchParams.get('session_id');\r\n  })",[2370,2422],"[getSessionId, location, navigate, updateSubscriptionAfterPayment]",[1594,1596],"[loading, refreshSubscription, subscription]",[1336,1396],"[location.state, navigate, isAuthenticated, location.search, getRedirectUrl]",[1943,1945],"[removeToast]",[2017,2053],"[forceRefreshSubscription, getSessionId, navigate]",[396,398],"[refreshSubscription]"]